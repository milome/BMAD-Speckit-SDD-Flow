{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "critical-auditor-profile.schema/v1",
  "type": "object",
  "required": [
    "metadata",
    "registryBindings",
    "stageProfiles",
    "perspectives",
    "dimensionContractBinding",
    "checkItemSetBinding",
    "auditRoundPolicy",
    "roundReceiptContract",
    "convergenceReceiptContract",
    "failClosedPolicy",
    "auditCallPointRegistry",
    "triadOrchestrationPolicy",
    "subagentIndependencePolicy",
    "mainAgentRepairPolicy",
    "repairReceiptFeedbackPolicy"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "profileId",
        "profileVersion",
        "profileHash",
        "schemaVersion",
        "createdAt",
        "authoritativeFor"
      ],
      "properties": {
        "profileId": { "type": "string" },
        "profileVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "profileHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "schemaVersion": { "const": "critical-auditor-profile/v1" },
        "createdAt": { "type": "string" },
        "authoritativeFor": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": true
    },
    "registryBindings": { "type": "object" },
    "stageProfiles": {
      "type": "object",
      "required": [
        "requirements_compiler",
        "implementation_readiness",
        "post_implementation_code_audit",
        "delivery_confirmation"
      ],
      "additionalProperties": { "$ref": "#/$defs/stageProfile" }
    },
    "perspectives": {
      "type": "array",
      "items": { "enum": ["product_intent", "model_projection", "main_agent_execution"] },
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true
    },
    "dimensionContractBinding": { "type": "object" },
    "checkItemSetBinding": { "type": "object" },
    "auditRoundPolicy": { "type": "object" },
    "roundReceiptContract": { "type": "object" },
    "convergenceReceiptContract": { "type": "object" },
    "failClosedPolicy": { "type": "object" },
    "auditCallPointRegistry": { "type": "object" },
    "triadOrchestrationPolicy": { "type": "object" },
    "subagentIndependencePolicy": { "type": "object" },
    "mainAgentRepairPolicy": { "type": "object" },
    "repairReceiptFeedbackPolicy": { "type": "object" }
  },
  "$defs": {
    "stageProfile": {
      "type": "object",
      "required": [
        "stageProfileId",
        "owningStages",
        "dimensionContractId",
        "dimensionMode",
        "expectedDimensions",
        "requiredCheckItemIds",
        "vetoItemIds",
        "stageProfileHash"
      ],
      "properties": {
        "stageProfileId": { "type": "string" },
        "owningStages": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "dimensionContractId": { "type": "string" },
        "dimensionMode": { "type": "string" },
        "expectedDimensions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "requiredCheckItemIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "vetoItemIds": { "type": "array", "items": { "type": "string" } },
        "stageProfileHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
