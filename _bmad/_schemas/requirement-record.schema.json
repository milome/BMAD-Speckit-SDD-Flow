{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmad-speckit.local/schemas/requirement-record.schema.json",
  "title": "Requirement Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordId",
    "requirementSetId",
    "status",
    "sourceDocumentHash",
    "implementationConfirmationHash",
    "confirmationHistory"
  ],
  "properties": {
    "recordId": { "$ref": "#/$defs/nonEmptyString" },
    "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
    "sourcePath": { "$ref": "#/$defs/nonEmptyString" },
    "status": {
      "enum": ["draft", "user_confirmed", "reconfirm_required", "in_progress", "blocked", "closed"]
    },
    "entryFlow": { "enum": ["story", "bugfix", "standalone_tasks"] },
    "entryFlowClass": { "enum": ["full_story_entry", "corrective_entry", "task_packet_entry"] },
    "workflowAdapter": { "enum": ["bmad", "speckit", "direct", "legacy"] },
    "contractAuthoringRequired": { "const": true },
    "globalContractTraceabilityPolicy": { "$ref": "#/$defs/globalContractTraceabilityPolicy" },
    "traceStatusPolicy": { "$ref": "#/$defs/traceStatusPolicy" },
    "runtimePolicySnapshotRef": { "$ref": "#/$defs/artifactRef" },
    "sourceDocumentHash": { "$ref": "#/$defs/sha256" },
    "implementationConfirmationHash": { "$ref": "#/$defs/sha256" },
    "confirmationPageHash": { "$ref": "#/$defs/sha256" },
    "confirmationHistory": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/confirmationEvent" }
    },
    "architectureConfirmationState": { "$ref": "#/$defs/architectureConfirmationState" },
    "architectureConfirmations": {
      "type": "array",
      "items": { "$ref": "#/$defs/architectureConfirmationEvent" }
    },
    "architectureConfirmationStateChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/architectureConfirmationStateCheck" }
    },
    "executionIterations": {
      "type": "array",
      "items": { "$ref": "#/$defs/executionIteration" }
    },
    "requirementClosures": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirementClosure" }
    },
    "gateChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/gateCheck" }
    },
    "contractChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/contractCheck" }
    },
    "failureRecords": {
      "type": "array",
      "items": { "$ref": "#/$defs/failureRecord" }
    },
    "rcaRecords": {
      "type": "array",
      "items": { "$ref": "#/$defs/rcaRecord" }
    },
    "rerunLoops": {
      "type": "array",
      "items": { "$ref": "#/$defs/rerunLoop" }
    },
    "closeout": { "$ref": "#/$defs/closeout" },
    "artifactIndex": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRef" }
    },
    "extensionRefs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactRef" }
    },
    "deliveryEvidence": { "$ref": "#/$defs/deliveryEvidence" },
    "hookReconciliation": { "$ref": "#/$defs/hookReconciliation" },
    "lastEventType": { "$ref": "#/$defs/nonEmptyString" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "not": {
    "anyOf": [
      { "required": ["dashboard"] },
      { "required": ["score"] },
      { "required": ["report"] },
      { "required": ["result"] }
    ]
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "globalContractTraceabilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "appliesToEntryFlows",
        "contractAuthoringRequired",
        "taskBindingRequired",
        "taskBindingDimensions",
        "missingBindingBehavior",
        "sourceDocumentHashRequired",
        "implementationConfirmationHashRequired",
        "reconfirmOnTraceSemanticChange",
        "allowUnboundImplementationTask"
      ],
      "properties": {
        "schemaVersion": { "const": "global-contract-traceability-policy/v1" },
        "appliesToEntryFlows": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "enum": ["story", "bugfix", "standalone_tasks"] }
        },
        "contractAuthoringRequired": { "const": true },
        "taskBindingRequired": { "const": true },
        "taskBindingDimensions": {
          "type": "array",
          "minItems": 5,
          "items": { "enum": ["MUST", "NEG", "OUT", "EVD", "TRACE"] },
          "contains": { "const": "MUST" }
        },
        "missingBindingBehavior": { "const": "fail_closed" },
        "sourceDocumentHashRequired": { "const": true },
        "implementationConfirmationHashRequired": { "const": true },
        "reconfirmOnTraceSemanticChange": { "const": true },
        "allowUnboundImplementationTask": { "const": false },
        "taskRegistryField": { "$ref": "#/$defs/nonEmptyString" },
        "traceTaskRefsMustResolveTo": { "$ref": "#/$defs/nonEmptyString" },
        "readinessFailureWhenUnresolved": { "const": true },
        "closeoutFailureWhenUnresolved": { "const": true }
      },
      "allOf": [
        { "properties": { "appliesToEntryFlows": { "contains": { "const": "story" } } } },
        { "properties": { "appliesToEntryFlows": { "contains": { "const": "bugfix" } } } },
        { "properties": { "appliesToEntryFlows": { "contains": { "const": "standalone_tasks" } } } },
        { "properties": { "taskBindingDimensions": { "contains": { "const": "NEG" } } } },
        { "properties": { "taskBindingDimensions": { "contains": { "const": "OUT" } } } },
        { "properties": { "taskBindingDimensions": { "contains": { "const": "EVD" } } } },
        { "properties": { "taskBindingDimensions": { "contains": { "const": "TRACE" } } } }
      ]
    },
    "traceStatusPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "allowedStatuses",
        "terminalFullCloseoutStatuses",
        "linkedDownstreamRequiredFields",
        "userApprovedDeferredRequiredFields",
        "userApprovedOutOfScopeRequiredFields",
        "bareDeferredForbidden",
        "bareOutOfScopeForbidden",
        "fullCloseoutForUserScopedStatusesForbidden"
      ],
      "properties": {
        "schemaVersion": { "const": "trace-status-policy/v1" },
        "allowedStatuses": {
          "type": "array",
          "minItems": 6,
          "items": {
            "enum": [
              "PENDING",
              "PASS",
              "FAIL",
              "BLOCKED",
              "LINKED_DOWNSTREAM",
              "USER_APPROVED_DEFERRED",
              "USER_APPROVED_OUT_OF_SCOPE"
            ]
          }
        },
        "terminalFullCloseoutStatuses": {
          "type": "array",
          "minItems": 3,
          "items": { "enum": ["PASS", "FAIL", "BLOCKED"] }
        },
        "linkedDownstreamRequiredFields": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "userApprovedDeferredRequiredFields": {
          "type": "array",
          "minItems": 5,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "userApprovedOutOfScopeRequiredFields": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "bareDeferredForbidden": { "const": true },
        "bareOutOfScopeForbidden": { "const": true },
        "fullCloseoutForUserScopedStatusesForbidden": { "const": true }
      },
      "allOf": [
        { "properties": { "allowedStatuses": { "contains": { "const": "PENDING" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "PASS" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "FAIL" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "BLOCKED" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "LINKED_DOWNSTREAM" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "USER_APPROVED_DEFERRED" } } } },
        { "properties": { "allowedStatuses": { "contains": { "const": "USER_APPROVED_OUT_OF_SCOPE" } } } },
        { "properties": { "terminalFullCloseoutStatuses": { "contains": { "const": "PASS" } } } },
        { "properties": { "terminalFullCloseoutStatuses": { "contains": { "const": "FAIL" } } } },
        { "properties": { "terminalFullCloseoutStatuses": { "contains": { "const": "BLOCKED" } } } }
      ]
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "id"],
      "properties": {
        "sourceType": { "$ref": "#/$defs/nonEmptyString" },
        "id": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "rerunAuthoritySourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "id"],
      "properties": {
        "sourceType": {
          "enum": [
            "gate_check",
            "contract_check",
            "audit_iteration",
            "execution_iteration",
            "requirement_closure"
          ]
        },
        "id": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "commandRunRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commandId", "command", "runId", "exitCode", "startedAt", "completedAt"],
      "properties": {
        "commandId": { "$ref": "#/$defs/nonEmptyString" },
        "command": { "$ref": "#/$defs/nonEmptyString" },
        "runId": { "$ref": "#/$defs/nonEmptyString" },
        "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" },
        "exitCode": { "type": "integer" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "outputSummary": { "type": "string" }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactType",
        "sourceOfTruthRole",
        "path",
        "producer",
        "purpose",
        "relatedRequirementIds",
        "status",
        "inputVersion",
        "outputVersion"
      ],
      "properties": {
        "eventType": { "$ref": "#/$defs/nonEmptyString" },
        "artifactType": { "$ref": "#/$defs/nonEmptyString" },
        "sourceOfTruthRole": {
          "enum": ["control", "evidence", "projection", "read_model"]
        },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "$ref": "#/$defs/nonEmptyString" },
        "hash": { "$ref": "#/$defs/sha256" },
        "contentHash": { "$ref": "#/$defs/sha256" },
        "producer": { "$ref": "#/$defs/nonEmptyString" },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "relatedRequirementIds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "status": { "enum": ["active", "superseded", "archived", "deleted", "blocked"] },
        "inputVersion": { "$ref": "#/$defs/nonEmptyString" },
        "outputVersion": { "$ref": "#/$defs/nonEmptyString" },
        "traceRows": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      },
      "anyOf": [
        { "required": ["hash"] },
        { "required": ["contentHash"] }
      ]
    },
    "confirmationEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventType",
        "recordId",
        "requirementSetId",
        "confirmedAt",
        "confirmedBy",
        "sourcePath",
        "sourceDocumentHash",
        "implementationConfirmationHash",
        "confirmationPageHash",
        "confirmationText",
        "renderReportPath",
        "htmlPath"
      ],
      "properties": {
        "eventType": { "const": "confirmation_recorded" },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "confirmedBy": { "$ref": "#/$defs/nonEmptyString" },
        "sourcePath": { "$ref": "#/$defs/nonEmptyString" },
        "sourceDocumentHash": { "$ref": "#/$defs/sha256" },
        "sourceDocumentHashScope": { "$ref": "#/$defs/nonEmptyString" },
        "implementationConfirmationHash": { "$ref": "#/$defs/sha256" },
        "implementationConfirmationHashScope": { "$ref": "#/$defs/nonEmptyString" },
        "confirmationPageHash": { "$ref": "#/$defs/sha256" },
        "confirmationText": { "$ref": "#/$defs/nonEmptyString" },
        "renderReportPath": { "$ref": "#/$defs/nonEmptyString" },
        "htmlPath": { "$ref": "#/$defs/nonEmptyString" },
        "entryFlow": { "enum": ["story", "bugfix", "standalone_tasks"] },
        "entryFlowClass": { "enum": ["full_story_entry", "corrective_entry", "task_packet_entry"] },
        "workflowAdapter": { "enum": ["bmad", "speckit", "direct", "legacy"] },
        "contractAuthoringRequired": { "const": true },
        "globalContractTraceabilityPolicy": { "$ref": "#/$defs/globalContractTraceabilityPolicy" },
        "traceStatusPolicy": { "$ref": "#/$defs/traceStatusPolicy" }
      }
    },
    "architectureConfirmationState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "currentArchitectureConfirmationHash"],
      "properties": {
        "status": { "enum": ["active", "stale", "missing", "blocked"] },
        "currentArchitectureConfirmationRunId": { "$ref": "#/$defs/nonEmptyString" },
        "currentArchitectureConfirmationHash": { "$ref": "#/$defs/sha256" },
        "currentArchitectureConfirmationPath": { "$ref": "#/$defs/nonEmptyString" },
        "resolvedRecipeHash": { "$ref": "#/$defs/sha256" },
        "staleInputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
        },
        "lastEventType": { "$ref": "#/$defs/nonEmptyString" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "architectureConfirmationEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventType",
        "recordId",
        "requirementSetId",
        "runId",
        "decision",
        "sourceDocumentHash",
        "implementationConfirmationHash",
        "resolvedRecipeHash",
        "architectureConfirmationArtifactHash",
        "architectureConfirmationPath",
        "confirmedAt",
        "confirmedBy"
      ],
      "properties": {
        "eventType": { "const": "architecture_confirmation_recorded" },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "runId": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["full_architecture_confirmed", "lightweight_architecture_confirmed", "architecture_reaudit_blocked"] },
        "sourceDocumentHash": { "$ref": "#/$defs/sha256" },
        "implementationConfirmationHash": { "$ref": "#/$defs/sha256" },
        "resolvedRecipeHash": { "$ref": "#/$defs/sha256" },
        "architectureConfirmationHashRecipe": {
          "type": "object",
          "additionalProperties": true
        },
        "architectureConfirmationArtifactHash": { "$ref": "#/$defs/sha256" },
        "targetPathsHash": { "$ref": "#/$defs/sha256" },
        "consumerImpactScanHash": { "$ref": "#/$defs/sha256" },
        "governanceImpactScanHash": { "$ref": "#/$defs/sha256" },
        "staleInputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
        },
        "artifactRef": { "$ref": "#/$defs/artifactRef" },
        "architectureConfirmationPath": { "$ref": "#/$defs/nonEmptyString" },
        "renderReportPath": { "$ref": "#/$defs/nonEmptyString" },
        "htmlPath": { "$ref": "#/$defs/nonEmptyString" },
        "confirmationText": { "$ref": "#/$defs/nonEmptyString" },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "confirmedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "architectureConfirmationStateCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "checkId", "decision", "resolvedRecipeHash", "stateTransition", "checkedAt", "checkedBy"],
      "properties": {
        "eventType": { "const": "architecture_confirmation_state_checked" },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "checkId": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["pass", "fail", "blocked"] },
        "resolvedRecipeHash": { "$ref": "#/$defs/sha256" },
        "stateTransition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fromStatus", "toStatus", "reasonCode", "previousHashes", "currentHashes", "mismatchFields", "recipeVersion"],
          "properties": {
            "fromStatus": { "enum": ["active", "stale", "blocked", "missing", "superseded"] },
            "toStatus": { "enum": ["active", "stale", "blocked", "missing", "superseded"] },
            "reasonCode": { "$ref": "#/$defs/nonEmptyString" },
            "previousHashes": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
            },
            "currentHashes": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
            },
            "mismatchFields": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "recipeVersion": { "const": "architecture-confirmation-hash/v1" }
          }
        },
        "checkedAt": { "type": "string", "format": "date-time" },
        "checkedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "executionIteration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventType",
        "recordId",
        "requirementSetId",
        "executionIterationId",
        "runId",
        "status",
        "traceRows",
        "evidenceRefs",
        "sourceDocumentHash",
        "implementationConfirmationHash",
        "architectureConfirmationHash",
        "recordedAt",
        "recordedBy"
      ],
      "properties": {
        "eventType": { "const": "execution_iteration_recorded" },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "executionIterationId": { "$ref": "#/$defs/nonEmptyString" },
        "runId": { "$ref": "#/$defs/nonEmptyString" },
        "status": {
          "enum": ["pending", "running", "done", "partial", "blocked", "failed", "timeout", "cancelled", "rerun_required"]
        },
        "traceRows": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "taskRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "filesChanged": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "diffSummary": { "type": "string" },
        "commandRunRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandRunRef" }
        },
        "evidenceArtifactRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "sourceDocumentHash": { "$ref": "#/$defs/sha256" },
        "implementationConfirmationHash": { "$ref": "#/$defs/sha256" },
        "architectureConfirmationHash": { "$ref": "#/$defs/sha256" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "requirementClosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "recordId", "requirementSetId", "requirementId", "status", "recordedAt", "recordedBy"],
      "properties": {
        "eventType": { "const": "requirement_closure_recorded" },
        "recordId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementSetId": { "$ref": "#/$defs/nonEmptyString" },
        "requirementId": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["open", "pass", "fail", "blocked"] },
        "traceRows": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "evidenceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "commandRunRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandRunRef" }
        },
        "evidenceArtifactRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "gateCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "gate", "decision"],
      "properties": {
        "eventType": { "const": "gate_check_recorded" },
        "checkId": { "$ref": "#/$defs/nonEmptyString" },
        "gate": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["pass", "fail", "blocked", "not_applicable", "skipped_by_policy"] },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "commandRunRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandRunRef" }
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "contractCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "contract", "decision"],
      "properties": {
        "eventType": { "const": "contract_check_recorded" },
        "checkId": { "$ref": "#/$defs/nonEmptyString" },
        "contract": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["pass", "fail", "blocked", "not_applicable", "skipped_by_policy"] },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "failureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "failureId", "type", "status", "sourceRefs", "recordedAt", "recordedBy"],
      "properties": {
        "eventType": { "const": "failure_recorded" },
        "failureId": { "$ref": "#/$defs/nonEmptyString" },
        "type": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["open", "in_progress", "resolved", "blocked", "superseded"] },
        "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" },
        "blockingReasons": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      },
      "not": {
        "anyOf": [
          { "required": ["result"] },
          { "required": ["decision"] }
        ]
      }
    },
    "rcaRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventType", "rcaId", "type", "status", "sourceRefs"],
      "properties": {
        "eventType": { "const": "rca_created" },
        "rcaId": { "$ref": "#/$defs/nonEmptyString" },
        "type": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["open", "in_progress", "resolved", "blocked"] },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "recordedAt": { "type": "string", "format": "date-time" },
        "recordedBy": { "$ref": "#/$defs/nonEmptyString" }
      },
      "not": {
        "anyOf": [
          { "required": ["result"] },
          { "required": ["decision"] }
        ]
      }
    },
    "rerunLoop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rerunLoopId", "status", "sourceRefs"],
      "properties": {
        "rerunLoopId": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "enum": ["open", "in_progress", "no_progress", "resolved", "blocked", "abandoned_by_user_confirmation"] },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rerunAuthoritySourceRef" }
        },
        "blockerRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        },
        "recheckRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "not": {
        "anyOf": [
          { "required": ["result"] },
          { "required": ["decision"] }
        ]
      }
    },
    "closeout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentAttemptId", "attempts"],
      "properties": {
        "currentAttemptId": { "$ref": "#/$defs/nonEmptyString" },
        "decision": { "enum": ["pass", "fail", "blocked"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "attempts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["eventType", "closeoutAttemptId", "decision"],
            "properties": {
              "eventType": { "const": "closeout_check_recorded" },
              "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" },
              "decision": { "enum": ["pass", "fail", "blocked"] },
              "blockingReasons": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "checks": {
                "type": "array",
                "items": { "type": "object" }
              },
              "reportPath": { "$ref": "#/$defs/nonEmptyString" },
              "evaluatedAt": { "type": "string", "format": "date-time" },
              "evaluatedBy": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        }
      }
    },
    "hookReconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "hostKind",
        "hostMode",
        "hookTrust",
        "fallbackMode",
        "closeoutReconciled",
        "sequenceLedger",
        "missingReceipts",
        "hashMismatches",
        "noHookFallbackRefs"
      ],
      "properties": {
        "schemaVersion": { "const": "hook-reconciliation/v1" },
        "hostKind": { "enum": ["codex", "cursor", "claude", "unknown"] },
        "hostMode": { "enum": ["hooks_enabled", "no_hooks", "unknown"] },
        "hookTrust": { "enum": ["trusted", "degraded", "untrusted", "unknown"] },
        "fallbackMode": { "enum": ["none", "no_hooks", "bounded_replay", "blocked"] },
        "closeoutReconciled": { "type": "boolean" },
        "sequenceLedger": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["clean", "reconciled", "gap", "missing", "stale", "unknown"] },
            "expectedNextSequence": { "type": "integer", "minimum": 0 },
            "observedSequences": {
              "type": "array",
              "items": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "missingReceipts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["receiptType", "expectedEventId"],
            "properties": {
              "receiptType": { "$ref": "#/$defs/nonEmptyString" },
              "expectedEventId": { "$ref": "#/$defs/nonEmptyString" },
              "severity": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "hashMismatches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "expected", "actual"],
            "properties": {
              "field": { "$ref": "#/$defs/nonEmptyString" },
              "expected": { "$ref": "#/$defs/nonEmptyString" },
              "actual": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "noHookFallbackRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "hookTrust": { "enum": ["degraded", "untrusted"] },
              "closeoutReconciled": { "const": true },
              "fallbackMode": { "enum": ["no_hooks", "bounded_replay"] }
            },
            "required": ["hookTrust", "closeoutReconciled", "fallbackMode"]
          },
          "then": {
            "properties": {
              "noHookFallbackRefs": { "minItems": 1 }
            }
          }
        }
      ],
      "not": {
        "required": ["result"]
      }
    },
    "deliveryEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["commandId", "command", "blockingIfMissing", "artifactRefs"],
            "properties": {
              "commandId": { "$ref": "#/$defs/nonEmptyString" },
              "command": { "$ref": "#/$defs/nonEmptyString" },
              "commandType": { "$ref": "#/$defs/nonEmptyString" },
              "blockingIfMissing": { "const": true },
              "negativeOrRegression": { "type": "boolean" },
              "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" },
              "lastRunRef": {
                "type": "object",
                "additionalProperties": false,
                "required": ["commandId", "runId", "closeoutAttemptId"],
                "properties": {
                  "commandId": { "$ref": "#/$defs/nonEmptyString" },
                  "runId": { "$ref": "#/$defs/nonEmptyString" },
                  "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" }
                }
              },
              "traceRows": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "evidenceRefs": {
                "type": "array",
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "artifactRefs": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/artifactRef" }
              }
            }
          }
        },
        "historicalRunRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["commandId", "runId"],
            "properties": {
              "commandId": { "$ref": "#/$defs/nonEmptyString" },
              "runId": { "$ref": "#/$defs/nonEmptyString" },
              "closeoutAttemptId": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        }
      }
    }
  }
}
