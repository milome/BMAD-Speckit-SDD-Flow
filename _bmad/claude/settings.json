{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/runtime-policy-inject.js\"",
            "timeout": 8,
            "statusMessage": "Emitting runtime governance policy..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-agent-summary.js\"",
            "timeout": 5,
            "statusMessage": "Generating agent call summary..."
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-create-sibling.js\"",
            "timeout": 30,
            "statusMessage": "Creating worktree in sibling directory..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/runtime-policy-inject.js\" --subagent-start",
            "timeout": 8,
            "statusMessage": "Injecting runtime governance policy..."
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-milestone-init.js\"",
            "timeout": 5,
            "statusMessage": "Initializing milestone tracking..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-result-summary.js\"",
            "timeout": 10,
            "statusMessage": "Composing result summary..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.js\"",
            "timeout": 10,
            "statusMessage": "Capturing runtime tool trace..."
          }
        ]
      }
    ]
  }
}
