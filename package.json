    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bmad-speckit": "1.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@bmad-speckit/ralph-method": "1.0.3",
    "@bmad-speckit/runtime-context": "1.0.3",
    "@bmad-speckit/runtime-emit": "1.0.3",
    "@bmad-speckit/schema": "1.0.3",
    "@bmad-speckit/scoring": "1.0.3",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
