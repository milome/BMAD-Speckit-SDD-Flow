    "scripts",
    "tests/acceptance",
    "docs/assets",
    "docs/ops",
    "docs/reference",
    "README.zh-CN.md",
    "docs/how-to/codex-setup.md",
    "_bmad-output/runtime/governance/user_story_mapping.json",
    "packages/scoring",
    "packages/runtime-context/src",
    "packages/runtime-context/package.json"
  ],
  "keywords": [
