{
  "name": "bmad-speckit-sdd-flow",
  "version": "0.1.0",
  "description": "BMAD + Speckit workflow and scoring skeleton; deploy _bmad to project root",
  "scripts": {
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "postinstall": "node scripts/init-to-root.js",
    "init": "node scripts/init-to-root.js",
    "init:claude": "node scripts/init-to-root.js --agent claude-code",
    "init:cursor": "node scripts/init-to-root.js --agent cursor",
    "setup": "pwsh scripts/setup.ps1",
    "setup:sh": "bash scripts/setup.sh",
    "setup:full": "pwsh scripts/setup.ps1 -Full",
    "setup:full:sh": "bash scripts/setup.sh -Full",
    "test": "npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit",
    "emit-runtime-policy": "npx ts-node --project tsconfig.node.json --transpile-only scripts/emit-runtime-policy.ts",
    "audit-prompt:resolve": "npx ts-node --project tsconfig.node.json --transpile-only scripts/i18n/print-resolved-audit-prompt.ts",
    "test:runtime-policy-inject": "vitest run tests/acceptance/runtime-policy-emit-stable.test.ts tests/acceptance/runtime-policy-inject.test.ts tests/acceptance/runtime-policy-emit-schema-ajv.test.ts",
    "test:runtime-dashboard-ui-smoke": "npx ts-node --project tsconfig.node.json --transpile-only tests/acceptance/runtime-dashboard-ui-playwright.smoke.ts",
    "test:governance-audit:playwright-ui": "npm run test:runtime-dashboard-ui-smoke",
    "test:governance-audit:round1": "npx vitest run tests/acceptance/governance-post-tool-use-hook.test.ts tests/acceptance/governance-post-tool-use-background-worker.test.ts tests/acceptance/governance-remediation-runner.test.ts tests/acceptance/governance-runtime-worker.test.ts tests/acceptance/governance-stop-hook-worker.test.ts tests/acceptance/prompt-routing-governance.test.ts tests/acceptance/prompt-routing-hints.test.ts tests/acceptance/model-governance-policy-filter.test.ts tests/acceptance/governance-provider-adapter.test.ts",
    "test:governance-audit:round2": "npx vitest run tests/acceptance/readiness-remediation-artifact-generation.test.ts tests/acceptance/readiness-remediation-artifact-wiring.test.ts tests/acceptance/governance-runner-lock.test.ts",
    "test:governance-audit:static": "pwsh -NoProfile -Command \"rg -n 'dashboard-\\*\\.png|^outputs/$|^test-results/$|^tests/typecheck/$|packages/scoring/outputs/' .gitignore; Test-Path docs/plans/runtime-dashboard-cherry-pick-checklist.md; Test-Path docs/plans/runtime-dashboard-cherry-pick-decision-summary.md; Test-Path docs/plans/runtime-dashboard-cherry-pick-execution-playbook.md; rg -n 'runtime-dashboard-cherry-pick-(checklist|decision-summary|execution-playbook)' docs/plans/runtime-dashboard-cherry-pick-checklist.md docs/plans/runtime-dashboard-cherry-pick-decision-summary.md docs/plans/runtime-dashboard-cherry-pick-execution-playbook.md\"",
    "test:governance-audit:extended": "npx vitest run tests/acceptance/governance-post-tool-use-hook.test.ts tests/acceptance/governance-post-tool-use-background-worker.test.ts tests/acceptance/governance-remediation-runner.test.ts tests/acceptance/governance-runtime-worker.test.ts tests/acceptance/governance-stop-hook-worker.test.ts tests/acceptance/prompt-routing-governance.test.ts tests/acceptance/prompt-routing-hints.test.ts tests/acceptance/model-governance-policy-filter.test.ts tests/acceptance/governance-provider-adapter.test.ts tests/acceptance/readiness-remediation-artifact-generation.test.ts tests/acceptance/readiness-remediation-artifact-wiring.test.ts tests/acceptance/governance-runner-summary-format.test.ts tests/acceptance/governance-runner-summary-presenter.test.ts tests/acceptance/skill-inventory-provider.test.ts tests/acceptance/governance-remediation-cross-stage-runner.test.ts tests/acceptance/governance-remediation-wave2a-tail.test.ts tests/acceptance/governance-runner-summary-e2e.test.ts tests/acceptance/governance-runtime-worker-cross-stage.test.ts tests/acceptance/governance-runtime-worker-scoring-event.test.ts tests/acceptance/governance-stop-hook-worker-cross-stage.test.ts tests/acceptance/governance-hook-jsdoc-types.test.ts tests/acceptance/brief-gate-loop-wave1b.test.ts tests/acceptance/brief-prd-arch-gate-loop-e2e.test.ts tests/acceptance/audit-contract-propagation-wave1b.test.ts tests/acceptance/implement-workflow-contract-propagation-wave1b.test.ts tests/acceptance/scoring-journey-contract-propagation-wave1b.test.ts tests/acceptance/tasks-journey-trace-contract-wave1b.test.ts tests/acceptance/governance-runner-lock.test.ts packages/scoring/__tests__/integration/dashboard-governance-routing.test.ts packages/scoring/analytics/__tests__/governance-history-metrics.test.ts packages/scoring/analytics/__tests__/governance-routing-summary.test.ts packages/scoring/analytics/__tests__/journey-contract-signals.test.ts packages/scoring/dashboard/__tests__/compute.test.ts packages/scoring/dashboard/__tests__/format.test.ts packages/scoring/gate/__tests__/remediation-hints.test.ts packages/scoring/orchestrator/__tests__/parse-and-write.test.ts",
    "test:governance-audit:full": "npm run test:governance-audit:round1 && npm run test:governance-audit:round2 && npm run test:governance-audit:static",
    "test:ci": "npm run init:claude && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:ci:cursor": "npm run init:cursor && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:ci:dual": "npm run init:claude && npm run init:cursor && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:scoring": "vitest run packages/scoring",
    "test:speckit-mirror-sync": "node scripts/verify-speckit-mirror-sync.js",
    "test:bmad-speckit": "cd packages/bmad-speckit && node --test tests/",
    "accept:e1-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e1-s1.ts",
    "accept:e1-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e1-s2.ts",
    "accept:e2-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e2-s1.ts",
    "accept:e2-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e2-s2.ts",
    "accept:e3-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s1.ts",
    "accept:e3-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s2.ts",
    "accept:e3-s3": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s3.ts",
    "accept:e4-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s1.ts",
    "accept:e4-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s2.ts",
    "accept:e4-s3": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s3.ts",
    "test:cursor-regression": "npx vitest run tests/acceptance/accept-cursor-regression-gate.test.ts && npm run accept:e1-s1 && npm run accept:e1-s2 && npm run accept:e3-s1 && npm run accept:e3-s2 && npm run accept:e3-s3 && npm run accept:e4-s1 && npm run accept:e4-s2 && npm run accept:e4-s3",
    "test:claude-isolation": "npx vitest run tests/acceptance/accept-claude-install-isolation.test.ts tests/acceptance/accept-claude-runtime-isolation.test.ts",
    "test:bmad": "npx vitest run tests/acceptance/accept-bmad-audit-parser.test.ts tests/acceptance/accept-bmad-auditors.test.ts tests/acceptance/accept-bmad-master-auto-continue.test.ts tests/acceptance/accept-bmad-master.test.ts tests/acceptance/accept-bmad-protocols.test.ts tests/acceptance/accept-bmad-state-skeleton.test.ts tests/acceptance/accept-layer4-e2e.test.ts tests/acceptance/accept-layer4.test.ts tests/acceptance/accept-commit-gate.test.ts tests/acceptance/accept-runtime.test.ts tests/acceptance/accept-speckit-checklist.test.ts tests/acceptance/accept-extensions.test.ts tests/acceptance/accept-install-consumer-cli.test.ts tests/acceptance/accept-pack-bmad-speckit.test.ts tests/acceptance/runtime-v6-sync-protected-paths.test.ts tests/acceptance/runtime-upstream-s8-sync-wiring.test.ts tests/acceptance/runtime-upstream-s9-sync-wiring.test.ts tests/acceptance/runtime-upstream-s10-sync-wiring.test.ts tests/acceptance/runtime-upstream-s11-sync-wiring.test.ts tests/acceptance/accept-init-package-json.test.ts",
    "coach:diagnose": "npx ts-node --project tsconfig.node.json scripts/coach-diagnose.ts",
    "verify:cursor-audit-granularity": "npx ts-node --project tsconfig.node.json scripts/verify-cursor-audit-granularity.ts",
    "eval-questions": "npx ts-node --project tsconfig.node.json scripts/eval-questions-cli.ts",
    "build:scoring": "cd packages/scoring && npm run build",
    "build:runtime-dashboard-ui": "npm run build:dashboard-ui -w @bmad-speckit/scoring",
    "build:runtime-context": "npm run build -w @bmad-speckit/runtime-context",
    "build:runtime-emit": "npm run build -w @bmad-speckit/runtime-emit",
    "prepublishOnly": "npm run build:scoring && npm run build:runtime-context && npm run build:runtime-emit && node scripts/prepublish-check.js",
    "speckit": "npx bmad-speckit",
    "speckit:init": "npx bmad-speckit init",
    "check": "npx bmad-speckit check",
    "test:fresh-regression": "npx ts-node --transpile-only scripts/run-fresh-regression-matrix.ts"
  },
  "bin": {
    "bmad-speckit-init": "scripts/init-to-root.js",
    "bmad-speckit-setup": "scripts/setup.ps1",
    "bmad-speckit-setup-sh": "scripts/setup.sh"
  },
  "files": [
    "_bmad",
    "scripts"
  ],
  "keywords": [
    "bmad",
    "speckit",
    "cursor",
    "workflow"
  ],
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bmad-speckit": "file:packages/bmad-speckit",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "playwright": "^1.58.2",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bmad-speckit": "file:packages/bmad-speckit",
    "js-yaml": "^4.1.1"
  }
}
