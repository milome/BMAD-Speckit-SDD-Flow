{
  "name": "bmad-speckit-sdd-flow",
  "version": "0.1.0",
  "description": "BMAD + Speckit workflow and scoring skeleton; deploy _bmad to project root",
  "scripts": {
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "postinstall": "node scripts/init-to-root.js",
    "init": "node scripts/init-to-root.js",
    "init:claude": "node scripts/init-to-root.js --agent claude-code",
    "init:cursor": "node scripts/init-to-root.js --agent cursor",
    "setup": "pwsh scripts/setup.ps1",
    "setup:sh": "bash scripts/setup.sh",
    "setup:full": "pwsh scripts/setup.ps1 -Full",
    "setup:full:sh": "bash scripts/setup.sh -Full",
    "test": "vitest run && npm run test:bmad-speckit",
    "emit-runtime-policy": "npx ts-node --transpile-only scripts/emit-runtime-policy.ts",
    "audit-prompt:resolve": "npx ts-node --transpile-only scripts/i18n/print-resolved-audit-prompt.ts",
    "test:runtime-policy-inject": "vitest run tests/acceptance/runtime-policy-emit-stable.test.ts tests/acceptance/runtime-policy-inject.test.ts tests/acceptance/runtime-policy-emit-schema-ajv.test.ts",
    "test:ci": "npm run init:claude && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:ci:cursor": "npm run init:cursor && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:ci:dual": "npm run init:claude && npm run init:cursor && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject",
    "test:scoring": "vitest run packages/scoring",
    "test:bmad-speckit": "cd packages/bmad-speckit && node --test tests/",
    "accept:e1-s1": "npx ts-node tests/epic-acceptance/accept-e1-s1.ts",
    "accept:e1-s2": "npx ts-node tests/epic-acceptance/accept-e1-s2.ts",
    "accept:e2-s1": "npx ts-node tests/epic-acceptance/accept-e2-s1.ts",
    "accept:e2-s2": "npx ts-node tests/epic-acceptance/accept-e2-s2.ts",
    "accept:e3-s1": "npx ts-node tests/epic-acceptance/accept-e3-s1.ts",
    "accept:e3-s2": "npx ts-node tests/epic-acceptance/accept-e3-s2.ts",
    "accept:e3-s3": "npx ts-node tests/epic-acceptance/accept-e3-s3.ts",
    "accept:e4-s1": "npx ts-node tests/epic-acceptance/accept-e4-s1.ts",
    "accept:e4-s2": "npx ts-node tests/epic-acceptance/accept-e4-s2.ts",
    "accept:e4-s3": "npx ts-node tests/epic-acceptance/accept-e4-s3.ts",
    "test:cursor-regression": "npx vitest run tests/acceptance/accept-cursor-regression-gate.test.ts && npm run accept:e1-s1 && npm run accept:e1-s2 && npm run accept:e3-s1 && npm run accept:e3-s2 && npm run accept:e3-s3 && npm run accept:e4-s1 && npm run accept:e4-s2 && npm run accept:e4-s3",
    "test:claude-isolation": "npx vitest run tests/acceptance/accept-claude-install-isolation.test.ts tests/acceptance/accept-claude-runtime-isolation.test.ts",
    "test:bmad": "npx vitest run tests/acceptance/accept-bmad-audit-parser.test.ts tests/acceptance/accept-bmad-auditors.test.ts tests/acceptance/accept-bmad-master-auto-continue.test.ts tests/acceptance/accept-bmad-master.test.ts tests/acceptance/accept-bmad-protocols.test.ts tests/acceptance/accept-bmad-state-skeleton.test.ts tests/acceptance/accept-layer4-e2e.test.ts tests/acceptance/accept-layer4.test.ts tests/acceptance/accept-commit-gate.test.ts tests/acceptance/accept-runtime.test.ts tests/acceptance/accept-speckit-checklist.test.ts tests/acceptance/accept-extensions.test.ts tests/acceptance/accept-install-consumer-cli.test.ts tests/acceptance/accept-pack-bmad-speckit.test.ts tests/acceptance/runtime-v6-sync-protected-paths.test.ts tests/acceptance/runtime-upstream-s8-sync-wiring.test.ts tests/acceptance/runtime-upstream-s9-sync-wiring.test.ts tests/acceptance/runtime-upstream-s10-sync-wiring.test.ts tests/acceptance/runtime-upstream-s11-sync-wiring.test.ts tests/acceptance/accept-init-package-json.test.ts",
    "coach:diagnose": "npx ts-node scripts/coach-diagnose.ts",
    "verify:cursor-audit-granularity": "npx ts-node scripts/verify-cursor-audit-granularity.ts",
    "eval-questions": "npx ts-node scripts/eval-questions-cli.ts",
    "build:scoring": "cd packages/scoring && npm run build",
    "build:runtime-context": "npm run build -w @bmad-speckit/runtime-context",
    "build:runtime-emit": "npm run build -w @bmad-speckit/runtime-emit",
    "prepublishOnly": "npm run build:scoring && npm run build:runtime-context && npm run build:runtime-emit && node scripts/prepublish-check.js",
    "speckit": "npx bmad-speckit",
    "speckit:init": "npx bmad-speckit init",
    "check": "npx bmad-speckit check",
    "test:fresh-regression": "npx ts-node --transpile-only scripts/run-fresh-regression-matrix.ts"
  },
  "bin": {
    "bmad-speckit-init": "scripts/init-to-root.js",
    "bmad-speckit-setup": "scripts/setup.ps1",
    "bmad-speckit-setup-sh": "scripts/setup.sh"
  },
  "files": [
    "_bmad",
    "scripts"
  ],
  "keywords": [
    "bmad",
    "speckit",
    "cursor",
    "workflow"
  ],
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "bmad-speckit": "file:packages/bmad-speckit"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bmad-speckit": "file:packages/bmad-speckit",
    "js-yaml": "^4.1.1"
  }
}
