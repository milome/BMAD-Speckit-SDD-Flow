{
  "name": "bmad-speckit-sdd-flow",
  "version": "1.0.3",
  "description": "BMAD + Speckit workflow and scoring skeleton; deploy _bmad to project root",
  "scripts": {
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "format:check": "prettier --check \"packages/scoring/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\"",
    "postinstall": "node scripts/init-to-root.js",
    "init": "node scripts/init-to-root.js",
    "init:claude": "node scripts/init-to-root.js --agent claude-code",
    "init:cursor": "node scripts/init-to-root.js --agent cursor",
    "init:codex": "node scripts/init-to-root.js --agent codex",
    "setup": "pwsh scripts/setup.ps1",
    "setup:sh": "bash scripts/setup.sh",
    "setup:full": "pwsh scripts/setup.ps1 -Full",
    "setup:full:sh": "bash scripts/setup.sh -Full",
    "test": "npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit",
    "main-agent-orchestration": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-orchestration.ts",
    "main-agent:run-loop": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-orchestration.ts --action run-loop",
    "main-agent:release-gate": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-release-gate.ts",
    "main-agent:quality-gate": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-quality-gate.ts",
    "main-agent:architecture-drift-check": "npx ts-node --project tsconfig.node.json --transpile-only scripts/architecture-drift-check.ts",
    "main-agent:soak-contract": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-soak-runner.ts --contract-8h",
    "main-agent:long-run-soak": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-soak-runner.ts",
    "test:main-agent-long-run-soak": "npx vitest run --config vitest.long-run.config.ts",
    "main-agent:host-matrix-pr-orchestrate": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-host-matrix-pr-orchestrator.ts",
    "main-agent:dual-host-pr-orchestrate": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-dual-host-pr-orchestrator.ts",
    "main-agent:delivery-truth-gate": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-delivery-truth-gate.ts",
    "main-agent:delivery-evidence-run": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-delivery-evidence-run.ts",
    "main-agent:bmad-help-five-layer-matrix": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-bmad-help-five-layer-matrix.ts",
    "main-agent:codex-worker": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-codex-worker-adapter.ts",
    "main-agent:development-journey-matrix": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-development-journey-matrix.ts",
    "main-agent:adaptive-intake-proof": "npx ts-node --project tsconfig.node.json --transpile-only scripts/adaptive-intake-proof-gate.ts --contract-fixture",
    "test:main-agent-chaos": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-chaos-scenarios.ts",
    "test:main-agent-sprint-status-write-gate": "npx vitest run tests/acceptance/sprint-status-authorized-update.test.ts tests/acceptance/sprint-status-unauthorized-write-deny.test.ts",
    "e2e:host-matrix:journey": "npx ts-node --project tsconfig.node.json --transpile-only scripts/e2e-host-matrix-journey-runner.ts --mode mock --hosts cursor,claude,codex",
    "e2e:dual-host:journey": "npx ts-node --project tsconfig.node.json --transpile-only scripts/e2e-dual-host-journey-runner.ts --mode mock --hosts cursor,claude,codex",
    "test:e2e:host-matrix:journey": "npx vitest run tests/acceptance/e2e-host-matrix-journey-runner.test.ts",
    "test:e2e:dual-host:journey": "npm run test:e2e:host-matrix:journey",
    "smoke:main-agent-runtime": "npx ts-node --project tsconfig.node.json --transpile-only scripts/live-smoke-main-agent-runtime.ts",
    "smoke:speckit-workflow": "npx ts-node --project tsconfig.node.json --transpile-only scripts/live-smoke-speckit-workflow.ts",
    "emit-runtime-policy": "npx ts-node --project tsconfig.node.json --transpile-only scripts/emit-runtime-policy.ts",
    "audit-prompt:resolve": "npx ts-node --project tsconfig.node.json --transpile-only scripts/i18n/print-resolved-audit-prompt.ts",
    "prepack": "node scripts/normalize-pack-manifests.js prepare",
    "postpack": "node scripts/normalize-pack-manifests.js restore",
    "test:runtime-policy-inject": "vitest run tests/acceptance/runtime-policy-emit-stable.test.ts tests/acceptance/runtime-policy-inject.test.ts tests/acceptance/runtime-policy-emit-schema-ajv.test.ts",
    "test:cursor-party-mode-hooks": "npm run test:cursor-party-mode-hooks:min",
    "test:cursor-party-mode-hooks:min": "npx vitest run tests/acceptance/runtime-step-state-glob.test.ts tests/acceptance/runtime-policy-inject.test.ts",
    "test:cursor-party-mode-hooks:extended": "npx vitest run tests/acceptance/runtime-step-state-glob.test.ts tests/acceptance/runtime-policy-inject.test.ts tests/acceptance/cursor-party-mode-current-session.test.ts tests/acceptance/party-mode-read-current-session.test.ts tests/acceptance/cursor-party-mode-return-diagnostic-contract.test.ts tests/acceptance/cursor-party-mode-document-path-contract.test.ts",
    "test:runtime-dashboard-ui-smoke": "npx ts-node --project tsconfig.node.json --transpile-only tests/acceptance/runtime-dashboard-ui-playwright.smoke.ts",
    "test:governance-audit:playwright-ui": "npm run test:runtime-dashboard-ui-smoke",
    "test:governance-cursor-headless-e2e": "npx vitest run tests/acceptance/governance-cursor-headless-e2e.test.ts",
    "test:governance-audit:round1": "npx vitest run tests/acceptance/governance-post-tool-use-hook.test.ts tests/acceptance/governance-remediation-runner.test.ts tests/acceptance/fallback-autonomous-dispatch-mode.test.ts tests/acceptance/main-agent-fallback-plane-hard-cut.test.ts tests/acceptance/fallback-plane-cross-stage-hard-cut.test.ts tests/acceptance/fallback-plane-execution-record-hard-cut.test.ts tests/acceptance/fallback-plane-scoring-event-hard-cut.test.ts tests/acceptance/pre-continue-state-machine-binding.test.ts tests/acceptance/prompt-routing-governance.test.ts tests/acceptance/prompt-routing-hints.test.ts tests/acceptance/model-governance-policy-filter.test.ts tests/acceptance/governance-provider-adapter.test.ts",
    "test:governance-audit:round2": "npx vitest run tests/acceptance/readiness-remediation-artifact-generation.test.ts tests/acceptance/readiness-remediation-artifact-wiring.test.ts tests/acceptance/legacy-detached-runner-surface.test.ts",
    "test:governance-audit:static": "pwsh -NoProfile -Command \"rg -n 'dashboard-\\*\\.png|^outputs/$|^test-results/$|^tests/typecheck/$|packages/scoring/outputs/' .gitignore; Test-Path docs/plans/runtime-dashboard-cherry-pick-checklist.md; Test-Path docs/plans/runtime-dashboard-cherry-pick-decision-summary.md; Test-Path docs/plans/runtime-dashboard-cherry-pick-execution-playbook.md; rg -n 'runtime-dashboard-cherry-pick-(checklist|decision-summary|execution-playbook)' docs/plans/runtime-dashboard-cherry-pick-checklist.md docs/plans/runtime-dashboard-cherry-pick-decision-summary.md docs/plans/runtime-dashboard-cherry-pick-execution-playbook.md\"",
    "test:governance-audit:extended": "npx vitest run tests/acceptance/governance-post-tool-use-hook.test.ts tests/acceptance/governance-remediation-runner.test.ts tests/acceptance/fallback-autonomous-dispatch-mode.test.ts tests/acceptance/main-agent-fallback-plane-hard-cut.test.ts tests/acceptance/fallback-plane-cross-stage-hard-cut.test.ts tests/acceptance/fallback-plane-execution-record-hard-cut.test.ts tests/acceptance/fallback-plane-scoring-event-hard-cut.test.ts tests/acceptance/pre-continue-state-machine-binding.test.ts tests/acceptance/prompt-routing-governance.test.ts tests/acceptance/prompt-routing-hints.test.ts tests/acceptance/model-governance-policy-filter.test.ts tests/acceptance/governance-provider-adapter.test.ts tests/acceptance/readiness-remediation-artifact-generation.test.ts tests/acceptance/readiness-remediation-artifact-wiring.test.ts tests/acceptance/governance-runner-summary-format.test.ts tests/acceptance/governance-runner-summary-presenter.test.ts tests/acceptance/skill-inventory-provider.test.ts tests/acceptance/governance-remediation-cross-stage-runner.test.ts tests/acceptance/governance-remediation-wave2a-tail.test.ts tests/acceptance/governance-runner-summary-e2e.test.ts tests/acceptance/governance-hook-jsdoc-types.test.ts tests/acceptance/brief-gate-loop-wave1b.test.ts tests/acceptance/brief-prd-arch-gate-loop-e2e.test.ts tests/acceptance/audit-contract-propagation-wave1b.test.ts tests/acceptance/implement-workflow-contract-propagation-wave1b.test.ts tests/acceptance/scoring-journey-contract-propagation-wave1b.test.ts tests/acceptance/tasks-journey-trace-contract-wave1b.test.ts tests/acceptance/legacy-detached-runner-surface.test.ts packages/scoring/__tests__/integration/dashboard-governance-routing.test.ts packages/scoring/analytics/__tests__/governance-history-metrics.test.ts packages/scoring/analytics/__tests__/governance-routing-summary.test.ts packages/scoring/analytics/__tests__/journey-contract-signals.test.ts packages/scoring/dashboard/__tests__/compute.test.ts packages/scoring/dashboard/__tests__/format.test.ts packages/scoring/gate/__tests__/remediation-hints.test.ts packages/scoring/orchestrator/__tests__/parse-and-write.test.ts",
    "test:governance-audit:full": "npm run test:governance-audit:round1 && npm run test:governance-audit:round2 && npm run test:governance-audit:static",
    "test:ci": "npm run init:claude && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject && npm run main-agent:release-gate && npm run main-agent:quality-gate && npm run test:main-agent-chaos",
    "test:ci:cursor": "npm run init:cursor && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject && npm run main-agent:release-gate && npm run main-agent:quality-gate && npm run test:main-agent-chaos",
    "test:ci:dual": "npm run init:claude && npm run init:cursor && npm run test:speckit-mirror-sync && vitest run && npm run test:bmad-speckit && npm run test:runtime-policy-inject && npm run main-agent:release-gate && npm run main-agent:quality-gate && npm run test:main-agent-chaos",
    "test:scoring": "vitest run packages/scoring",
    "test:speckit-mirror-sync": "node scripts/verify-speckit-mirror-sync.js",
    "test:bmad-speckit": "npm run test --prefix packages/bmad-speckit",
    "accept:e1-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e1-s1.ts",
    "accept:e1-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e1-s2.ts",
    "accept:e2-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e2-s1.ts",
    "accept:e2-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e2-s2.ts",
    "accept:e3-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s1.ts",
    "accept:e3-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s2.ts",
    "accept:e3-s3": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e3-s3.ts",
    "accept:e4-s1": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s1.ts",
    "accept:e4-s2": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s2.ts",
    "accept:e4-s3": "npx ts-node --project tsconfig.node.json tests/epic-acceptance/accept-e4-s3.ts",
    "test:cursor-regression": "npx vitest run tests/acceptance/accept-cursor-regression-gate.test.ts && npm run accept:e1-s1 && npm run accept:e1-s2 && npm run accept:e3-s1 && npm run accept:e3-s2 && npm run accept:e3-s3 && npm run accept:e4-s1 && npm run accept:e4-s2 && npm run accept:e4-s3",
    "test:claude-isolation": "npx vitest run tests/acceptance/accept-claude-install-isolation.test.ts tests/acceptance/accept-claude-runtime-isolation.test.ts",
    "test:bmad": "npx vitest run tests/acceptance/accept-bmad-audit-parser.test.ts tests/acceptance/accept-bmad-auditors.test.ts tests/acceptance/accept-bmad-master-auto-continue.test.ts tests/acceptance/accept-bmad-master.test.ts tests/acceptance/accept-bmad-protocols.test.ts tests/acceptance/accept-bmad-state-skeleton.test.ts tests/acceptance/accept-layer4-e2e.test.ts tests/acceptance/accept-layer4.test.ts tests/acceptance/accept-commit-gate.test.ts tests/acceptance/accept-runtime.test.ts tests/acceptance/accept-speckit-checklist.test.ts tests/acceptance/accept-extensions.test.ts tests/acceptance/accept-install-consumer-cli.test.ts tests/acceptance/accept-pack-bmad-speckit.test.ts tests/acceptance/runtime-v6-sync-protected-paths.test.ts tests/acceptance/runtime-upstream-s8-sync-wiring.test.ts tests/acceptance/runtime-upstream-s9-sync-wiring.test.ts tests/acceptance/runtime-upstream-s10-sync-wiring.test.ts tests/acceptance/runtime-upstream-s11-sync-wiring.test.ts tests/acceptance/accept-init-package-json.test.ts",
    "coach:diagnose": "npx ts-node --project tsconfig.node.json scripts/coach-diagnose.ts",
    "verify:cursor-audit-granularity": "npx ts-node --project tsconfig.node.json scripts/verify-cursor-audit-granularity.ts",
    "eval-questions": "npx ts-node --project tsconfig.node.json scripts/eval-questions-cli.ts",
    "build:scoring": "cd packages/scoring && npm run build",
    "build:ralph-method": "npm run build -w @bmad-speckit/ralph-method",
    "build:runtime-dashboard-ui": "npm run build:dashboard-ui -w @bmad-speckit/scoring",
    "build:runtime-context": "npm run build -w @bmad-speckit/runtime-context",
    "build:runtime-emit": "npm run build -w @bmad-speckit/runtime-emit",
    "verify:hooks": "node scripts/verify-hooks-no-ts-node.js",
    "prepublishOnly": "npm run verify:hooks && npm run build:scoring && npm run build:runtime-context && npm run build:runtime-emit && npm run build:ralph-method && node scripts/prepublish-check.js",
    "speckit": "npx bmad-speckit",
    "speckit:init": "npx bmad-speckit init",
    "check": "npx bmad-speckit check",
    "test:fresh-regression": "npx ts-node --transpile-only scripts/run-fresh-regression-matrix.ts",
    "validate:single-source-whitelist": "npx ts-node --project tsconfig.node.json --transpile-only scripts/validate-single-source-whitelist.ts",
    "test:main-agent-rerun-gate-e2e-loop": "npx vitest run tests/acceptance/governance-rerun-gate-closure.test.ts",
    "main-agent:inspect": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-orchestration.ts --cwd . --action inspect",
    "main-agent:dispatch-plan": "npx ts-node --project tsconfig.node.json --transpile-only scripts/main-agent-orchestration.ts --cwd . --action dispatch-plan",
    "test:ci:codex": "npm run init:codex && npx vitest run tests/acceptance/main-agent-codex-agent-parity.test.ts tests/acceptance/main-agent-codex-worker-adapter-e2e.test.ts tests/acceptance/main-agent-run-loop-e2e.test.ts tests/acceptance/main-agent-unified-ingress-e2e.test.ts tests/acceptance/orchestration-dispatch-contract.test.ts tests/acceptance/e2e-host-matrix-real-codex-smoke.test.ts tests/acceptance/main-agent-release-gate-contract.test.ts tests/acceptance/main-agent-delivery-truth-gate.test.ts tests/acceptance/main-agent-quality-gate-thresholds.test.ts tests/acceptance/main-agent-bmad-help-five-layer-matrix-e2e.test.ts tests/acceptance/main-agent-codex-consumer-five-layer-e2e.test.ts tests/acceptance/main-agent-codex-asset-host-leakage.test.ts tests/acceptance/reviewer-projection-parity.test.ts tests/acceptance/accept-install-consumer-cli.test.ts"
  },
  "bin": {
    "bmad-speckit-init": "scripts/init-to-root.js",
    "bmad-speckit-setup": "scripts/setup.ps1",
    "bmad-speckit-setup-sh": "scripts/setup.sh"
  },
