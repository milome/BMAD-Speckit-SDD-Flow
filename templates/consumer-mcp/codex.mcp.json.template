{
  "mcpServers": {
    "{{SERVER_NAME}}": {
      "command": "node",
      "args": [
        ".codex/mcp/{{SERVER_NAME}}/server/dist/index.js"
      ],
      "env": {
        "BMAD_PROJECT_ROOT": ".",
        "BMAD_ROOT": "_bmad",
        "BMAD_OUTPUT_ROOT": "_bmad-output",
        "BMAD_MCP_SERVER_CONFIG": ".codex/mcp/{{SERVER_NAME}}/server/config/server.config.json",
        "BMAD_MCP_LOG_DIR": ".codex/mcp/{{SERVER_NAME}}/server/logs",
        "BMAD_MCP_TMP_DIR": ".codex/mcp/{{SERVER_NAME}}/server/tmp"
      }
    }
  }
}

