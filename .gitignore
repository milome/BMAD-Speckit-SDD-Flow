# Dependencies
node_modules/

# Environment and secrets
.env
.env.*
*.key
*secret*
*.pem
secrets/

# Build and cache
dist/
build/
.cache/
.pytest_cache/
*.log
coverage/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# BMAD output
_bmad-output/

# Scoring runtime data (generated by scoring system during development)
packages/scoring/data/dev-*.json
packages/scoring/data/cli-*.json
packages/scoring/data/audit-*.json
packages/scoring/data/prompt-optimization-suggestions.md
packages/scoring/outputs/

# Runtime deployment artifacts (legacy root dirs, source: _bmad/)
/commands/
/rules/
/skills/

# Speckit runtime (deployed from _bmad/speckit/ by init-to-root / SyncService)
.specify/

# Cursor runtime
# commands/rules: deployed by init-to-root from _bmad/commands/ and _bmad/cursor/rules/
# skills: deployed to ~/.cursor/skills/ by SkillPublisher (not project-level)
# agents: deployed by init-to-root from config/
.cursor/commands/
.cursor/rules/
.cursor/skills/
.cursor/agents/

# Claude runtime (deployed by init-to-root / SyncService from _bmad/claude/)
# state: runtime session data, template source: _bmad/claude/state/ (if exists)
.claude/commands/
.claude/rules/
.claude/skills/
.claude/agents/
.claude/hooks/
.claude/protocols/
.claude/state/
.claude/settings.json
.claude/settings.local.json
.claude/mcp.json

# Agent / OMC runtime data
.agents/
.omc/

# Session temporary files
progress.txt
progress.md
findings.md
task_plan.md
dxdiag_output.txt
temp_commit_message.txt
*.backup-*.md

# Documentation archives
docs/BMAD/
docs/assets/
docs/design/
docs/examples/
docs/fixes/
docs/PR/
docs/plans/

# Worktrees
.worktrees/
.claude/worktrees/
