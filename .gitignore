/commands/
/rules/
/skills/

# Speckit runtime (deployed from _bmad/speckit/ by init-to-root / SyncService)
.specify/

# Cursor runtime
# Entire .cursor/ tree is treated as runtime deployed copy, not canonical source
.cursor/

# Claude runtime (deployed by init-to-root / SyncService from _bmad/claude/)
# Entire .claude/ tree is treated as runtime deployed copy, not canonical source
.claude/

# Agent / OMC runtime data
.agents/
.omc/
.serena/

