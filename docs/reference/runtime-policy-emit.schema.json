{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmad-speckit.local/schemas/runtime-policy-emit.json",
  "title": "RuntimePolicyEmit",
  "oneOf": [{ "$ref": "#/$defs/successPolicy" }, { "$ref": "#/$defs/errorBody" }],
  "$defs": {
    "auditConvergence": {
      "type": "object",
      "required": [
        "description",
        "rounds",
        "no_gap_required",
        "critical_auditor_ratio",
        "applicable_stages"
      ],
      "properties": {
        "description": { "type": "string" },
        "rounds": { "type": "integer" },
        "no_gap_required": { "type": "boolean" },
        "critical_auditor_ratio": { "type": "number" },
        "applicable_stages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "contextMaturityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactComplete": { "type": "boolean" },
        "fourSignalsComplete": { "type": "boolean" },
        "executionSpecific": { "type": "boolean" },
        "governanceHealthy": { "type": "boolean" },
        "runtimeScopeComplete": { "type": "boolean" },
        "followUpBudgetExhausted": { "type": "boolean" }
      }
    },
    "implementationReadinessEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "documentAuditPassed": { "type": "boolean" },
        "readinessReportPresent": { "type": "boolean" },
        "blockerCount": { "type": "integer" },
        "remediationState": {
          "type": "string",
          "enum": ["none", "in_progress", "closed"]
        },
        "rerunGateStatus": {
          "type": "string",
          "enum": ["unknown", "pass", "fail"]
        },
        "staleAfterSemanticChange": { "type": "boolean" }
      }
    },
    "complexityFactors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impactSurface",
        "sharedContract",
        "verificationCost",
        "uncertainty",
        "rollbackDifficulty",
        "forcedReasons"
      ],
      "properties": {
        "impactSurface": { "type": "integer", "minimum": 0, "maximum": 2 },
        "sharedContract": { "type": "integer", "minimum": 0, "maximum": 2 },
        "verificationCost": { "type": "integer", "minimum": 0, "maximum": 2 },
        "uncertainty": { "type": "integer", "minimum": 0, "maximum": 2 },
        "rollbackDifficulty": { "type": "integer", "minimum": 0, "maximum": 2 },
        "forcedReasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "implementationEntryGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gateName",
        "requestedFlow",
        "recommendedFlow",
        "decision",
        "readinessStatus",
        "blockerCodes",
        "blockerSummary",
        "rerouteRequired",
        "rerouteReason",
        "evidenceSources",
        "semanticFingerprint",
        "evaluatedAt"
      ],
      "properties": {
        "gateName": { "type": "string", "const": "implementation-readiness" },
        "requestedFlow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks"]
        },
        "recommendedFlow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks"]
        },
        "decision": {
          "type": "string",
          "enum": ["pass", "block", "reroute"]
        },
        "readinessStatus": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "repair_in_progress",
            "ready_clean",
            "repair_closed",
            "stale_after_semantic_change"
          ]
        },
        "blockerCodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockerSummary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rerouteRequired": { "type": "boolean" },
        "rerouteReason": { "type": ["string", "null"] },
        "evidenceSources": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readinessReportPath",
            "remediationArtifactPath",
            "executionRecordPath",
            "authoritativeAuditReportPath"
          ],
          "properties": {
            "readinessReportPath": { "type": ["string", "null"] },
            "remediationArtifactPath": { "type": ["string", "null"] },
            "executionRecordPath": { "type": ["string", "null"] },
            "authoritativeAuditReportPath": { "type": ["string", "null"] }
          }
        },
        "semanticFingerprint": { "type": ["string", "null"] },
        "evaluatedAt": { "type": "string" }
      }
    },
    "helpRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceMode",
        "contextMaturity",
        "complexity",
        "complexityScore",
        "complexityForcedReasons",
        "implementationReadinessStatus",
        "implementationEntryRecommended",
        "implementationEntryDecision",
        "shouldUpgradeStandaloneTasks",
        "recommendedFlow",
        "recommendationLabel",
        "rerouteRequired",
        "rerouteReason",
        "canonicalImplementationGate",
        "implementationEntryGate",
        "evidence",
        "evidenceSources",
        "executionRecordId",
        "mainAgentCanContinue",
        "continueStateSource",
        "continueDecision",
        "mainAgentNextAction",
        "mainAgentReady",
        "mainAgentOrchestration",
        "fiveLayerProgress"
      ],
      "properties": {
        "sourceMode": {
          "type": ["string", "null"],
          "enum": ["full_bmad", "seeded_solutioning", "standalone_story", null]
        },
        "contextMaturity": {
          "type": "string",
          "enum": ["minimal", "seeded", "full", "unclassified"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "complexityScore": { "type": "integer" },
        "complexityForcedReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "implementationReadinessStatus": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "repair_in_progress",
            "ready_clean",
            "repair_closed",
            "stale_after_semantic_change"
          ]
        },
        "implementationEntryRecommended": { "type": "boolean" },
        "implementationEntryDecision": {
          "type": "string",
          "enum": ["pass", "block", "reroute"]
        },
        "shouldUpgradeStandaloneTasks": { "type": "boolean" },
        "recommendedFlow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
        },
        "recommendationLabel": {
          "type": "string",
          "enum": ["recommended", "blocked"]
        },
        "rerouteRequired": { "type": "boolean" },
        "rerouteReason": { "type": ["string", "null"] },
        "canonicalImplementationGate": {
          "type": "string",
          "const": "implementation-readiness"
        },
        "implementationEntryGate": { "$ref": "#/$defs/implementationEntryGate" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contextMaturity", "implementationReadiness", "complexityFactors"],
          "properties": {
            "contextMaturity": { "$ref": "#/$defs/contextMaturityEvidence" },
            "implementationReadiness": {
              "$ref": "#/$defs/implementationReadinessEvidence"
            },
            "complexityFactors": { "$ref": "#/$defs/complexityFactors" }
          }
        },
        "evidenceSources": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readinessReportPath",
            "remediationArtifactPath",
            "executionRecordPath",
            "authoritativeAuditReportPath"
          ],
          "properties": {
            "readinessReportPath": { "type": ["string", "null"] },
            "remediationArtifactPath": { "type": ["string", "null"] },
            "executionRecordPath": { "type": ["string", "null"] },
            "authoritativeAuditReportPath": { "type": ["string", "null"] }
          }
        },
        "executionRecordId": { "type": ["string", "null"] },
        "mainAgentCanContinue": { "type": ["boolean", "null"] },
        "continueStateSource": {
          "type": "string",
          "enum": ["runtimeContext", "registry", "none"]
        },
        "continueDecision": {
          "type": ["string", "null"],
          "enum": ["continue", "rerun", "blocked", null]
        },
        "mainAgentNextAction": { "type": ["string", "null"] },
        "mainAgentReady": { "type": ["boolean", "null"] },
        "mainAgentOrchestration": { "$ref": "#/$defs/mainAgentOrchestration" },
        "fiveLayerProgress": { "$ref": "#/$defs/fiveLayerProgress" }
      }
    },
    "fiveLayerProgress": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "currentLayer",
        "currentStage",
        "nextRequiredLayer",
        "completedLayers",
        "stageStatuses"
      ],
      "properties": {
        "currentLayer": { "$ref": "#/$defs/fiveLayerId" },
        "currentStage": { "type": "string" },
        "nextRequiredLayer": { "$ref": "#/$defs/fiveLayerId" },
        "completedLayers": {
          "type": "array",
          "items": { "$ref": "#/$defs/fiveLayerId" }
        },
        "stageStatuses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["layer", "stage", "completed", "evidencePath"],
            "properties": {
              "layer": { "$ref": "#/$defs/fiveLayerId" },
              "stage": { "type": "string" },
              "completed": { "type": "boolean" },
              "evidencePath": { "type": "string" }
            }
          }
        }
      }
    },
    "fiveLayerId": {
      "type": "string",
      "enum": ["layer_1", "layer_2", "layer_3", "layer_4", "layer_5"]
    },
    "mainAgentOrchestration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "sessionId",
        "orchestrationStatePath",
        "orchestrationState",
        "pendingPacketStatus",
        "pendingPacket",
        "fourSignal",
        "latestGate",
        "gatesLoop",
        "closeout",
        "drift",
        "mainAgentCanContinue",
        "continueDecision",
        "mainAgentNextAction",
        "mainAgentReady"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["orchestration_state", "reviewer_closeout", "implementation_entry_gate", "none"]
        },
        "sessionId": { "type": ["string", "null"] },
        "orchestrationStatePath": { "type": ["string", "null"] },
        "orchestrationState": { "type": ["object", "null"] },
        "pendingPacketStatus": {
          "type": "string",
          "enum": [
            "none",
            "ready_for_main_agent",
            "claimed_by_main_agent",
            "dispatched",
            "completed",
            "invalidated",
            "missing_packet_file"
          ]
        },
        "pendingPacket": { "type": ["object", "null"] },
        "fourSignal": { "type": ["object", "null"] },
        "latestGate": { "type": ["object", "null"] },
        "gatesLoop": { "type": ["object", "null"] },
        "closeout": { "type": ["object", "null"] },
        "drift": { "type": ["object", "null"] },
        "mainAgentCanContinue": { "type": ["boolean", "null"] },
        "continueDecision": {
          "type": ["string", "null"],
          "enum": ["continue", "rerun", "blocked", null]
        },
        "mainAgentNextAction": { "type": ["string", "null"] },
        "mainAgentReady": { "type": ["boolean", "null"] }
      }
    },
    "reviewerContractProjection": {
      "type": "object",
      "additionalProperties": false,
        "required": [
          "version",
          "reviewerIdentity",
          "reviewerDisplayName",
          "facilitatorIdentity",
          "registryVersion",
          "sharedCore",
          "schemaVersions",
          "closeoutRunner",
          "governance",
          "hostAdapterBoundary",
          "compatibilityGuards",
          "requiredRolloutProofs",
          "rolloutGate",
          "supportedProfiles",
          "supportedAuditEntryStages",
          "activeAuditConsumer"
        ],
        "properties": {
        "version": { "type": "string", "const": "reviewer_contract_projection_v1" },
        "reviewerIdentity": { "type": "string", "const": "bmad_code_reviewer" },
          "reviewerDisplayName": { "type": "string", "const": "code-reviewer" },
          "facilitatorIdentity": { "type": "string", "const": "party_mode_facilitator" },
          "registryVersion": { "type": "string", "const": "reviewer_registry_v1" },
          "sharedCore": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "rootPath", "basePromptPath", "profilePackPath"],
            "properties": {
              "version": { "type": "string", "const": "reviewer_shared_core_v1" },
              "rootPath": { "type": "string" },
              "basePromptPath": { "type": "string" },
              "profilePackPath": { "type": "string" }
            }
          },
          "schemaVersions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input", "output", "handoff", "closeout"],
          "properties": {
            "input": { "type": "string", "const": "review_input_v1" },
            "output": { "type": "string", "const": "review_output_v1" },
            "handoff": { "type": "string", "const": "review_handoff_v1" },
            "closeout": { "type": "string", "const": "review_host_closeout_v1" }
            }
          },
          "closeoutRunner": { "type": "string", "const": "runAuditorHost" },
          "governance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "implementationReadinessStatusRequired",
              "implementationReadinessGateName",
              "gatesLoopRequired",
              "rerunGatesRequired",
              "packetExecutionClosureRequired",
              "packetExecutionClosureStatuses",
              "closeoutEnvelopeFields"
            ],
            "properties": {
              "implementationReadinessStatusRequired": { "const": true },
              "implementationReadinessGateName": { "type": "string", "const": "implementation-readiness" },
              "gatesLoopRequired": { "const": true },
              "rerunGatesRequired": { "const": true },
              "packetExecutionClosureRequired": { "const": true },
              "packetExecutionClosureStatuses": {
                "type": "array",
                "items": { "type": "string" }
              },
              "closeoutEnvelopeFields": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "hostAdapterBoundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "projectionOnly",
              "hostLocalStageSemanticsForbidden",
              "hostLocalRoutePrecedenceForbidden",
              "hostLocalFallbackBusinessRulesForbidden"
            ],
            "properties": {
              "projectionOnly": { "const": true },
              "hostLocalStageSemanticsForbidden": { "const": true },
              "hostLocalRoutePrecedenceForbidden": { "const": true },
              "hostLocalFallbackBusinessRulesForbidden": { "const": true }
            }
          },
          "compatibilityGuards": {
            "type": "object",
            "additionalProperties": false,
            "required": ["codexNoopRequired", "codexBehaviorChangeAllowed"],
            "properties": {
              "codexNoopRequired": { "const": false },
              "codexBehaviorChangeAllowed": { "const": true }
            }
          },
          "requiredRolloutProofs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rolloutGate": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "version",
              "status",
              "requiredProofs",
              "completeProofs",
              "blockingProofs",
              "cleanupAllowed",
              "canClaimFullIsomorphism",
              "summary"
            ],
            "properties": {
              "version": { "type": "string", "const": "reviewer_rollout_gate_v1" },
              "status": { "type": "string", "enum": ["blocked", "ready"] },
              "requiredProofs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "completeProofs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blockingProofs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cleanupAllowed": { "type": "boolean" },
              "canClaimFullIsomorphism": { "type": "boolean" },
              "summary": { "type": "string" }
            }
          },
          "supportedProfiles": {
            "type": "array",
            "items": { "type": "string" }
        },
        "supportedAuditEntryStages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "activeAuditConsumer": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "entryStage",
                "profile",
                "closeoutStage",
                "auditorScript",
                "scoreStage"
              ],
              "properties": {
                "entryStage": { "type": "string" },
                "profile": { "type": "string" },
                "closeoutStage": { "type": "string" },
                "auditorScript": { "type": "string" },
                "scoreStage": { "type": "string" },
                "triggerStage": { "type": "string" }
              }
            }
          ]
        }
      }
    },
    "successPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow",
        "stage",
        "auditRequired",
        "validationLevel",
        "strictness",
        "generateDoc",
        "convergence",
        "mandatoryGate",
        "granularityGoverned",
        "skipAllowed",
        "scoringEnabled",
        "triggerStage",
        "compatibilitySource",
        "reason",
        "contextMaturity",
        "complexity",
        "implementationReadinessStatus",
        "implementationEntryRecommended",
        "implementationEntryDecision",
        "implementationEntryGate",
        "helpRouting",
        "mainAgentCanContinue",
        "continueStateSource",
        "continueDecision",
        "mainAgentNextAction",
        "mainAgentReady",
        "mainAgentOrchestration",
        "reviewerContract",
        "identity",
        "control",
        "language",
        "fiveLayerProgress"
      ],
      "properties": {
        "flow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
        },
        "stage": { "type": "string" },
        "auditRequired": { "type": "boolean" },
        "validationLevel": {
          "type": ["string", "null"],
          "enum": ["basic", "test_only", "full_validation", null]
        },
        "strictness": { "type": "string", "enum": ["strict", "standard"] },
        "generateDoc": { "type": "boolean" },
        "convergence": { "$ref": "#/$defs/auditConvergence" },
        "mandatoryGate": { "type": "boolean" },
        "granularityGoverned": { "type": "boolean" },
        "skipAllowed": { "type": "boolean" },
        "scoringEnabled": { "type": "boolean" },
        "triggerStage": { "type": "string" },
        "compatibilitySource": {
          "type": "string",
          "enum": ["legacy", "shadow", "governance"]
        },
        "reason": { "type": "string" },
        "contextMaturity": {
          "type": "string",
          "enum": ["minimal", "seeded", "full", "unclassified"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "implementationReadinessStatus": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "repair_in_progress",
            "ready_clean",
            "repair_closed",
            "stale_after_semantic_change"
          ]
        },
        "implementationEntryRecommended": { "type": "boolean" },
        "implementationEntryDecision": {
          "type": "string",
          "enum": ["pass", "block", "reroute"]
        },
        "implementationEntryGate": { "$ref": "#/$defs/implementationEntryGate" },
        "helpRouting": { "$ref": "#/$defs/helpRouting" },
        "mainAgentCanContinue": { "type": ["boolean", "null"] },
        "continueStateSource": {
          "type": "string",
          "enum": ["runtimeContext", "registry", "none"]
        },
        "continueDecision": {
          "type": ["string", "null"],
          "enum": ["continue", "rerun", "blocked", null]
        },
        "mainAgentNextAction": { "type": ["string", "null"] },
        "mainAgentReady": { "type": ["boolean", "null"] },
        "mainAgentOrchestration": { "$ref": "#/$defs/mainAgentOrchestration" },
        "fiveLayerProgress": { "$ref": "#/$defs/fiveLayerProgress" },
        "reviewerContract": { "$ref": "#/$defs/reviewerContractProjection" },
        "identity": {
          "type": "object",
          "required": ["flow", "stage"],
          "additionalProperties": false,
          "properties": {
            "flow": {
              "type": "string",
              "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
            },
            "stage": { "type": "string" },
            "epicId": { "type": "string" },
            "storyId": { "type": "string" },
            "storySlug": { "type": "string" },
            "runId": { "type": "string" },
            "artifactRoot": { "type": "string" },
            "contextSource": { "type": "string" }
          }
        },
        "control": {
          "type": "object",
          "required": [
            "auditRequired",
            "validationLevel",
            "strictness",
            "generateDoc",
            "convergence",
            "mandatoryGate",
            "granularityGoverned",
            "skipAllowed",
            "scoringEnabled",
            "triggerStage",
            "reason"
          ],
          "additionalProperties": false,
          "properties": {
            "auditRequired": { "type": "boolean" },
            "validationLevel": {
              "type": ["string", "null"],
              "enum": ["basic", "test_only", "full_validation", null]
            },
            "strictness": { "type": "string", "enum": ["strict", "standard"] },
            "generateDoc": { "type": "boolean" },
            "convergence": { "$ref": "#/$defs/auditConvergence" },
            "mandatoryGate": { "type": "boolean" },
            "granularityGoverned": { "type": "boolean" },
            "skipAllowed": { "type": "boolean" },
            "scoringEnabled": { "type": "boolean" },
            "triggerStage": { "type": "string" },
            "reason": { "type": "string" }
          }
        },
        "language": {
          "type": "object",
          "required": ["preserveMachineKeys", "preserveParserAnchors", "preserveTriggerStage"],
          "additionalProperties": false,
          "properties": {
            "preserveMachineKeys": { "type": "boolean", "const": true },
            "preserveParserAnchors": { "type": "boolean", "const": true },
            "preserveTriggerStage": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "errorBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "reason"],
      "properties": {
        "error": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
