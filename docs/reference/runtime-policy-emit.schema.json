{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmad-speckit.local/schemas/runtime-policy-emit.json",
  "title": "RuntimePolicyEmit",
  "oneOf": [{ "$ref": "#/$defs/successPolicy" }, { "$ref": "#/$defs/errorBody" }],
  "$defs": {
    "auditConvergence": {
      "type": "object",
      "required": [
        "description",
        "rounds",
        "no_gap_required",
        "critical_auditor_ratio",
        "applicable_stages"
      ],
      "properties": {
        "description": { "type": "string" },
        "rounds": { "type": "integer" },
        "no_gap_required": { "type": "boolean" },
        "critical_auditor_ratio": { "type": "number" },
        "applicable_stages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "contextMaturityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactComplete": { "type": "boolean" },
        "fourSignalsComplete": { "type": "boolean" },
        "executionSpecific": { "type": "boolean" },
        "governanceHealthy": { "type": "boolean" },
        "runtimeScopeComplete": { "type": "boolean" },
        "followUpBudgetExhausted": { "type": "boolean" }
      }
    },
    "implementationReadinessEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "documentAuditPassed": { "type": "boolean" },
        "readinessReportPresent": { "type": "boolean" },
        "blockerCount": { "type": "integer" },
        "remediationState": {
          "type": "string",
          "enum": ["none", "in_progress", "closed"]
        },
        "rerunGateStatus": {
          "type": "string",
          "enum": ["unknown", "pass", "fail"]
        },
        "staleAfterSemanticChange": { "type": "boolean" }
      }
    },
    "complexityFactors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impactSurface",
        "sharedContract",
        "verificationCost",
        "uncertainty",
        "rollbackDifficulty",
        "forcedReasons"
      ],
      "properties": {
        "impactSurface": { "type": "integer", "minimum": 0, "maximum": 2 },
        "sharedContract": { "type": "integer", "minimum": 0, "maximum": 2 },
        "verificationCost": { "type": "integer", "minimum": 0, "maximum": 2 },
        "uncertainty": { "type": "integer", "minimum": 0, "maximum": 2 },
        "rollbackDifficulty": { "type": "integer", "minimum": 0, "maximum": 2 },
        "forcedReasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "helpRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceMode",
        "contextMaturity",
        "complexity",
        "complexityScore",
        "complexityForcedReasons",
        "implementationReadinessStatus",
        "implementationEntryRecommended",
        "shouldUpgradeStandaloneTasks",
        "recommendedFlow",
        "recommendationLabel",
        "canonicalImplementationGate",
        "evidence",
        "evidenceSources",
        "executionRecordId"
      ],
      "properties": {
        "sourceMode": {
          "type": ["string", "null"],
          "enum": ["full_bmad", "seeded_solutioning", "standalone_story", null]
        },
        "contextMaturity": {
          "type": "string",
          "enum": ["minimal", "seeded", "full", "unclassified"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "complexityScore": { "type": "integer" },
        "complexityForcedReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "implementationReadinessStatus": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "repair_in_progress",
            "ready_clean",
            "repair_closed",
            "stale_after_semantic_change"
          ]
        },
        "implementationEntryRecommended": { "type": "boolean" },
        "shouldUpgradeStandaloneTasks": { "type": "boolean" },
        "recommendedFlow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
        },
        "recommendationLabel": {
          "type": "string",
          "enum": ["recommended", "allowed but not recommended", "blocked"]
        },
        "canonicalImplementationGate": {
          "type": "string",
          "const": "implementation-readiness"
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contextMaturity", "implementationReadiness", "complexityFactors"],
          "properties": {
            "contextMaturity": { "$ref": "#/$defs/contextMaturityEvidence" },
            "implementationReadiness": {
              "$ref": "#/$defs/implementationReadinessEvidence"
            },
            "complexityFactors": { "$ref": "#/$defs/complexityFactors" }
          }
        },
        "evidenceSources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["readinessReportPath", "remediationArtifactPath", "executionRecordPath"],
          "properties": {
            "readinessReportPath": { "type": ["string", "null"] },
            "remediationArtifactPath": { "type": ["string", "null"] },
            "executionRecordPath": { "type": ["string", "null"] }
          }
        },
        "executionRecordId": { "type": ["string", "null"] }
      }
    },
    "successPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow",
        "stage",
        "auditRequired",
        "validationLevel",
        "strictness",
        "generateDoc",
        "convergence",
        "mandatoryGate",
        "granularityGoverned",
        "skipAllowed",
        "scoringEnabled",
        "triggerStage",
        "compatibilitySource",
        "reason",
        "contextMaturity",
        "complexity",
        "implementationReadinessStatus",
        "implementationEntryRecommended",
        "helpRouting",
        "identity",
        "control",
        "language"
      ],
      "properties": {
        "flow": {
          "type": "string",
          "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
        },
        "stage": { "type": "string" },
        "auditRequired": { "type": "boolean" },
        "validationLevel": {
          "type": ["string", "null"],
          "enum": ["basic", "test_only", "full_validation", null]
        },
        "strictness": { "type": "string", "enum": ["strict", "standard"] },
        "generateDoc": { "type": "boolean" },
        "convergence": { "$ref": "#/$defs/auditConvergence" },
        "mandatoryGate": { "type": "boolean" },
        "granularityGoverned": { "type": "boolean" },
        "skipAllowed": { "type": "boolean" },
        "scoringEnabled": { "type": "boolean" },
        "triggerStage": { "type": "string" },
        "compatibilitySource": {
          "type": "string",
          "enum": ["legacy", "shadow", "governance"]
        },
        "reason": { "type": "string" },
        "contextMaturity": {
          "type": "string",
          "enum": ["minimal", "seeded", "full", "unclassified"]
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "implementationReadinessStatus": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "repair_in_progress",
            "ready_clean",
            "repair_closed",
            "stale_after_semantic_change"
          ]
        },
        "implementationEntryRecommended": { "type": "boolean" },
        "helpRouting": { "$ref": "#/$defs/helpRouting" },
        "identity": {
          "type": "object",
          "required": ["flow", "stage"],
          "additionalProperties": false,
          "properties": {
            "flow": {
              "type": "string",
              "enum": ["story", "bugfix", "standalone_tasks", "epic", "unknown"]
            },
            "stage": { "type": "string" },
            "epicId": { "type": "string" },
            "storyId": { "type": "string" },
            "storySlug": { "type": "string" },
            "runId": { "type": "string" },
            "artifactRoot": { "type": "string" },
            "contextSource": { "type": "string" }
          }
        },
        "control": {
          "type": "object",
          "required": [
            "auditRequired",
            "validationLevel",
            "strictness",
            "generateDoc",
            "convergence",
            "mandatoryGate",
            "granularityGoverned",
            "skipAllowed",
            "scoringEnabled",
            "triggerStage",
            "reason"
          ],
          "additionalProperties": false,
          "properties": {
            "auditRequired": { "type": "boolean" },
            "validationLevel": {
              "type": ["string", "null"],
              "enum": ["basic", "test_only", "full_validation", null]
            },
            "strictness": { "type": "string", "enum": ["strict", "standard"] },
            "generateDoc": { "type": "boolean" },
            "convergence": { "$ref": "#/$defs/auditConvergence" },
            "mandatoryGate": { "type": "boolean" },
            "granularityGoverned": { "type": "boolean" },
            "skipAllowed": { "type": "boolean" },
            "scoringEnabled": { "type": "boolean" },
            "triggerStage": { "type": "string" },
            "reason": { "type": "string" }
          }
        },
        "language": {
          "type": "object",
          "required": ["preserveMachineKeys", "preserveParserAnchors", "preserveTriggerStage"],
          "additionalProperties": false,
          "properties": {
            "preserveMachineKeys": { "type": "boolean", "const": true },
            "preserveParserAnchors": { "type": "boolean", "const": true },
            "preserveTriggerStage": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "errorBody": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error", "reason"],
      "properties": {
        "error": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
