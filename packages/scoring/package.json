{
  "name": "@bmad-speckit/scoring",
  "version": "1.0.0",
  "description": "BMAD scoring system: audit parsing, score calculation, coach diagnosis, dashboard generation",
  "main": "dist/orchestrator/index.js",
  "types": "dist/orchestrator/index.d.ts",
  "exports": {
