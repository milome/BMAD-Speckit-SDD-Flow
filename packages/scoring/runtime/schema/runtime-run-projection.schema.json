{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RuntimeRunProjection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "status",
    "current_stage",
    "current_scope",
    "stage_history",
    "score_refs",
    "artifact_refs",
    "dataset_candidate_refs",
    "last_event_at"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "passed", "failed", "vetoed", "skipped"]
    },
    "current_stage": {
      "type": ["string", "null"]
    },
    "current_scope": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/definitions/runtimeScopeRef" }
      ]
    },
    "stage_history": {
      "type": "array",
      "items": { "$ref": "#/definitions/stageProjection" }
    },
    "score_refs": {
      "type": "array",
      "items": { "$ref": "#/definitions/scoreRef" }
    },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "#/definitions/artifactRef" }
    },
    "dataset_candidate_refs": {
      "type": "array",
      "items": { "$ref": "#/definitions/datasetCandidateRef" }
    },
    "last_event_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "definitions": {
    "runtimeScopeRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "story_key": { "type": "string", "minLength": 1 },
        "epic_id": { "type": "string", "minLength": 1 },
        "story_id": { "type": "string", "minLength": 1 },
        "flow": { "type": "string", "minLength": 1 },
        "template_id": { "type": "string", "minLength": 1 },
        "artifact_root": { "type": "string", "minLength": 1 },
        "resolved_context_path": { "type": "string", "minLength": 1 }
      }
    },
    "stageProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "passed", "failed", "vetoed", "skipped"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "scoreRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score_record_id": { "type": "string", "minLength": 1 },
        "stage": { "type": ["string", "null"] },
        "path": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "minLength": 1 }
      }
    },
    "datasetCandidateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_id"],
      "properties": {
        "sample_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["accepted", "rejected", "downgraded"]
        },
        "split_assignment": {
          "type": "string",
          "enum": ["train", "validation", "test", "holdout"]
        }
      }
    }
  }
}
