{
  "name": "@bmad-speckit/runtime-context",
  "version": "1.0.2",
  "description": "Runtime context registry and ensure-run CLI for BMAD workflows (published like @bmad-speckit/scoring)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "require": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./registry": {
      "require": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    },
    "./context": {
      "require": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./sync-from-sprint-cli": {
      "require": "./dist/sync-from-sprint-cli.js",
      "types": "./dist/sync-from-sprint-cli.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
