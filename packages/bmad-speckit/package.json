{
  "name": "bmad-speckit",
  "version": "1.0.2",
  "description": "Internal BMAD-Speckit CLI workspace bundled by bmad-speckit-sdd-flow",
  "private": true,
  "bin": {
    "bmad-speckit": "bin/bmad-speckit.js",
    "bmad-speckit-init": "bin/bmad-speckit-init.js"
  },
  "files": [
    "README.md",
    "bin/",
    "src/",
    "tests/",
    "test-nonempty/",
    "_bmad/",
    "node_modules/@bmad-speckit/"
  ],
  "scripts": {
    "prepack": "npm run build:scoring --prefix ../.. && npm run build:runtime-context --prefix ../.. && npm run build:runtime-emit --prefix ../.. && npm run build:ralph-method --prefix ../.. && node -e \"process.env.BMAD_PREPUBLISH_SILENT='1'; process.env.BMAD_PACK_SESSION='1'; require('../../scripts/prepublish-check.js')\"",
    "postpack": "node ../../scripts/cleanup-packed-bmad.js",
    "prepublishOnly": "node ../../scripts/prepublish-check.js",
    "test": "node scripts/run-node-tests.cjs"
  },
  "keywords": [
    "bmad",
    "speckit",
    "sdd",
    "init"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "bundleDependencies": [
    "@bmad-speckit/schema",
    "@bmad-speckit/scoring",
    "@bmad-speckit/runtime-context",
    "@bmad-speckit/runtime-emit",
    "@bmad-speckit/ralph-method"
  ],
  "devDependencies": {
    "nock": "^15.0.0"
  },
  "dependencies": {
    "@bmad-speckit/schema": "1.0.2",
    "@bmad-speckit/ralph-method": "1.0.2",
    "@bmad-speckit/runtime-emit": "1.0.2",
    "@bmad-speckit/runtime-context": "1.0.2",
    "@bmad-speckit/scoring": "1.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "boxen": "^8.0.0",
    "js-yaml": "^4.1.1",
    "ora": "^8.0.1",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "inquirer-autocomplete-prompt": "^3.0.1",
    "tar": "^7.0.0"
  }
}
