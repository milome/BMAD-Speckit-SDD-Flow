      "test:claude-isolation": "npx vitest run scripts/accept-claude-install-isolation.test.ts scripts/accept-claude-runtime-isolation.test.ts",
      "test:bmad": "npx vitest run scripts/accept-bmad-*.test.ts scripts/accept-layer4-*.test.ts scripts/accept-commit-gate.test.ts scripts/accept-runtime.test.ts scripts/accept-checklists.test.ts scripts/accept-extensions.test.ts",
